{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:server",
    "dev:web": "vite --config apps/web/vite.config.ts",
    "dev:toss": "vite --config apps/toss/vite.config.ts",
    "dev:server": "tsx apps/server/server.ts",
    "vite:clear-cache": "node scripts/clear-vite-cache.mjs",
    "dev:server:fresh": "node scripts/clear-vite-cache.mjs && tsx apps/server/server.ts",
    "build": "npm run build:web",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "build:toss": "vite build --config apps/toss/vite.config.ts",
    "ait:build": "node scripts/clean-toss-dist-for-ait.mjs && npx ait build",
    "ait:deploy": "npx ait deploy",
    "dev:granite": "npx granite dev",
    "android:reverse": "node scripts/android-adb-reverse.mjs",
    "start": "npm run dev:server",
    "preview": "vite preview --config apps/web/vite.config.ts",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "db:migrate:users": "tsx apply_users_migration.ts",
    "db:check:users": "tsx check_users_schema.ts",
    "db:backfill:user-identities": "tsx backfill_user_identities.ts"
  },
  "dependencies": {
    "@apps-in-toss/web-framework": "^2.3.0",
    "@emotion/react": "^11.14.0",
    "@google/genai": "^1.29.0",
    "@supabase/supabase-js": "^2.100.0",
    "@tailwindcss/vite": "^4.1.14",
    "@toss/tds-mobile": "^2.3.0",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "canvas-confetti": "^1.9.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.23",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pixi-filters": "^6.1.5",
    "pixi.js": "^8.17.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.21.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2"
  }
}